RAILS_ENV=development
GIT_EDITOR=/usr/local/bin/nvim

# Prevent Letter Opener from trying to open the browser to view emails
LAUNCHY_DRY_RUN=true
BROWSER=/dev/null

# Database configuration for development environment
PGUSER=postgres
PGPASSWORD=password

# Using a custom timezone to ensure that all timestamps are consistent across development environments
TZ=Asia/Bangkok
PGTZ=Asia/Bangkok

# Use sockets instead of TCP for local connections to Postgres and Redis
PGHOST=/var/run/postgresql
REDIS_URL=/data/socket/redis.sock

# Enable Ruby's debug gem to allow remote debugging sessions
RUBY_DEBUG_PORT=38698
RUBY_DEBUG_HOST=0.0.0.0
RUBY_DEBUG_IRB_CONSOLE=1

# Use Playwright for system tests, connecting to the Playwright server running in a separate container
PLAYWRIGHT_HOST=ws://playwright:8888

# Use a shared volume for gems to speed up bundle install and reduce disk usage across multiple containers
GEM_VOLUME=filial_shared_gems

# Custom terminal settings for development environment in containers
SSH_PATH=/home/jbigler/.ssh
TERM=xterm-kitty
SHELL=/bin/zsh

SKIP_TEST_DATABASE_TRUNCATE=1

GITHUB_TOKEN=${GITHUB_TOKEN}
